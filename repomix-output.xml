  return {
    bootstrap,
    completeOnboarding,
    hasCompletedOnboarding,
    isAuthenticated: status === "authenticated",
    isLoading: status === "checking",
    register,
    sessionToken,
    signIn,
    signOut,
    status,
  };
}
