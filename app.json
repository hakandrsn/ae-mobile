{
  "expo": {
    "name": "ae-mobil",
    "slug": "ae-mobil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aemobil",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "ExpoLocalization_supportsRTL": true,
        "CFBundleLocalizations": ["en", "tr", "ar"],
        "NSLocationWhenInUseUsageDescription": "Konumunuz haritada gösterilir ve size yakın ilanlar sunulur.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Konumunuz haritada gösterilir ve size yakın ilanlar sunulur."
      },
      "bundleIdentifier": "com.eoist.ae",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.eoist.ae"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "supportsRTL": true
    },
    "locales": {
      "en": "./locales/native/en.json",
      "tr": "./locales/native/tr.json",
      "ar": "./locales/native/ar.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": ["en", "tr", "ar"],
            "android": ["en", "tr", "ar"]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Figtree-VariableFont_wght.ttf"]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Konumunuz haritada gösterilir ve size yakın ilanlar sunulur.",
          "locationAlwaysAndWhenInUsePermission": "Konumunuz haritada gösterilir ve size yakın ilanlar sunulur."
        }
      ],
      "expo-image",
      "expo-web-browser"
    ]
  },
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": true
  }
}
